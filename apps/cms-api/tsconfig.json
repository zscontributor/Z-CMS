{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    // NestJS relies on decorator metadata, which requires the classic decorator
    // transform. This is why the API stays on CommonJS + TS 5.x rather than the
    // NodeNext/ESM setup the other packages use.
    "module": "CommonJS",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": false,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "types": ["node", "express", "multer"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
