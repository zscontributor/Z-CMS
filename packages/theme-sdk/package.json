{
  "name": "@zcmsorg/theme-sdk",
  "version": "0.1.0",
  "description": "The contract for writing a Z-CMS theme: templates, blocks, settings, SEO and translations.",
  "license": "MIT",
  "author": "Z-SOFT Co., Ltd. <support@z-cms.org> (https://z-cms.org)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zscontributor/z-cms.git",
    "directory": "packages/theme-sdk"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.esm.json && node scripts/esm-package.mjs",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@zcmsorg/schemas": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "react": "19.2.7",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "@vitest/coverage-v8": "4.1.10"
  },
  "homepage": "https://z-cms.org",
  "bugs": {
    "url": "https://github.com/zscontributor/z-cms/issues"
  }
}
