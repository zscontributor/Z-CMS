{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "noEmit": true,
    "types": [
      "node",
      "react"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
