{
  "name": "@zcmsorg/theme-default",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "description": "Z Default — the default Z-CMS theme.",
  "exports": {
    ".": "./src/index.tsx",
    "./theme.css": "./src/theme.css",
    "./theme.json": "./theme.json"
  },
  "files": ["src", "assets", "screenshots", "dist", "theme.json"],
  "scripts": {
    "build": "node build.mjs && tsx scripts/sync-assets.ts",
    "screenshots": "tsx ../../scripts/theme-screenshots.mts default",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zcmsorg/schemas": "workspace:*",
    "@zcmsorg/theme-sdk": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "esbuild": "0.25.12",
    "react": "19.2.7",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
