{
  "name": "@zcmsorg/plugin-runtime",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "verify:sandbox": "tsc -p tsconfig.build.json && node dist/verify-sandbox.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@zcmsorg/plugin-sdk": "workspace:*",
    "@zcmsorg/schemas": "workspace:*",
    "dotenv": "17.2.3",
    "express": "5.1.0",
    "isolated-vm": "6.0.1",
    "@zcmsorg/package": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "4.1.10",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
